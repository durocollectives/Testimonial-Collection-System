# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# Supabase — get these from your Supabase project settings
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=[anon-public-key]

# Supabase service role key — server-side only, NOT prefixed with VITE_
# Used by the /api/admin-testimonials Vercel function
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]

# Resend — server-side only, NOT prefixed with VITE_
# Get from resend.com/api-keys
RESEND_API_KEY=[re_...]

# Admin dashboard password
VITE_ADMIN_PASSWORD=[choose-a-strong-password]

# Email recipient for notifications
NOTIFICATION_EMAIL=tobi@tobiyusuf.com

# Your deployed Vercel URL (for the dashboard link in notification emails)
VITE_APP_URL=https://your-project.vercel.app
